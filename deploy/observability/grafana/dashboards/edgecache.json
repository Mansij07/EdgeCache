{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "EdgeCache Fleet",
  "uid": "edgecache-fleet",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Fleet hit rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(edgecache_requests_total{result=\"hit\"}[1m])) / clamp_min(sum(rate(edgecache_requests_total[1m])), 1)",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests/sec by result",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(edgecache_requests_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cache size per replica (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "edgecache_cache_size_bytes",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Origin latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(edgecache_origin_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Circuit breakers OPEN",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(edgecache_circuit_breaker_state{state=\"open\"})",
          "legendFormat": "open"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests coalesced / sec",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(edgecache_inflight_coalesced_total[1m]))",
          "legendFormat": "coalesced"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Purged keys / sec (fleet)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(edgecache_purged_keys_total[1m]))",
          "legendFormat": "purged keys"
        }
      ]
    }
  ]
}
