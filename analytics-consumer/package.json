{
  "name": "edgecache-analytics-consumer",
  "version": "1.0.0",
  "description": "Consumes EdgeCache access-log events from Kafka and rolls them into hourly per-path stats in Postgres.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
